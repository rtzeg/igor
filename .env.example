# ===========================================
# Application
# ===========================================
ENVIRONMENT=dev
APP_PORT=3000
NODE_ENV=production

# ===========================================
# Frontend Runtime Config
# Эти переменные доступны в браузере через window.__ENV__
# Добавляйте новые переменные в scripts/env.sh
# ===========================================
VITE_API_BASE_URL=http://localhost:8000
VITE_APP_NAME=MyApp
VITE_DEFAULT_LOCALE=ru

# ===========================================
# Nginx
# ===========================================
NGINX_CLIENT_MAX_BODY_SIZE=50m
